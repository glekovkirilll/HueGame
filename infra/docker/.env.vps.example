# Copy this file to infra/docker/.env.vps on the VPS and edit the values.

POSTGRES_DB=huegame
POSTGRES_USER=huegame
POSTGRES_PASSWORD=change-this-long-random-password

# Public domain served by Caddy. For this project:
APP_DOMAIN=hue.flipflop.site
ACME_EMAIL=admin@flipflop.site

# Use the same origin so Caddy can route Socket.IO websocket traffic.
NEXT_PUBLIC_BACKEND_URL=https://hue.flipflop.site:8443

HTTP_HOST_PORT=80
HTTPS_PORT=8443
ROUND_TICK_INTERVAL_MS=1000
APP_IMAGE_TAG=vps
